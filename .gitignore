# Never commit the cosign PRIVATE key (only cosign.pub belongs in git).
cosign.key
*.key

# Compiled Ignition (contains the Tailscale key + the server's SSH private key).
*.ign

# Provisioning secrets, injected at compile time by `butane --files-dir .`.
# The real files live here locally and never get committed; only the README and
# the *.example templates are tracked.
secrets/*
!secrets/README.md
!secrets/*.example

# Local ISO / build output.
output/
*.iso
