{
  "default": [
    { "type": "insecureAcceptAnything" }
  ],
  "transports": {
    "docker": {
      "ghcr.io/svkoulu": [
        {
          "type": "sigstoreSigned",
          "keyPath": "/etc/pki/containers/svk-cosign.pub",
          "signedIdentity": { "type": "matchRepoDigestOrExact" }
        }
      ]
    }
  }
}
