#!/usr/bin/bash
# stamp-os-release — write svk identity + build version into /usr/lib/os-release
# AND a machine-readable /usr/share/svk-os/image-info.json.
#
# Env-driven so svk-base AND each derived image (svk-student / svk-staff) can stamp
# their OWN identity: base runs it at branding time, the derived Containerfiles run
# it again (this file ships in the base image at /usr/libexec/svk/) so they stop
# reporting `svk-base`. Fedora's own VERSION_ID / OSTREE_VERSION (from the Silverblue
# base) are left untouched, so the Fedora version stays visible alongside ours.
#
# The JSON mirrors ublue's image-info.json idea but lives under svk-os/ (no ublue
# path/vendor). Nothing in the update path reads it — it's metadata for our own
# tooling/introspection (channel, version, release line, base) via `jq`.
#
#   IMAGE_NAME    (required)  e.g. svk-base / svk-student / svk-staff
#   IMAGE_FLAVOR  (optional)  short slug folded into PRETTY_NAME, e.g. staff | student
#                             (blank for svk-base, which has no flavor)
#   VERSION       (optional)  build version: stable-<N>-<date> | testing-<date>
#                             | local-<date> (blank -> no version in PRETTY_NAME)
#   GIT_SHA       (optional)  full git commit SHA of the svk repo this image was
#                             built from. Stamped as os-release BUILD_ID (systemd's
#                             own field for "uniquely identifies a particular build")
#                             and svk-os/image-info.json's git-commit — the way to
#                             go from a running/installed image back to its source
#                             commit, independent of VERSION's channel/date scheme.
#   IMAGE_VENDOR  (default svkoulu)
#
# NAME stays the constant OS family name "svk-os" across every image (base,
# student, staff) — per os-release(5) it's meant to identify the OS without a
# variant/version component, same as Fedora's own NAME="Fedora Linux" doesn't
# vary between Silverblue/Workstation/Server. The per-image identity that field
# used to carry (svk-staff / svk-student / svk-base) lives in IMAGE_ID instead —
# os-release(5)'s dedicated field for exactly this, already what bootc/ostree
# tooling looks at.
#
# PRETTY_NAME is always "SVK OS", plus a "(<flavor>-<version>)" parenthetical when
# either is set, e.g. "SVK OS (staff-stable-1-20260719)". This is the ONLY field
# the Anaconda WebUI installer (and GNOME's About page) actually reads for
# display — it never looks at IMAGE_VERSION, IMAGE_ID, or Fedora's own VERSION_ID,
# so the flavor/channel/version have to live in PRETTY_NAME itself or they never
# become visible anywhere a human looks. iso/installer/build.sh builds the
# identical string for the GRUB boot-menu entries, independently (no os-release to
# read yet at that point) — keep the two in sync if this format ever changes.
set -euo pipefail

: "${IMAGE_NAME:?stamp-os-release: IMAGE_NAME is required}"
IMAGE_FLAVOR="${IMAGE_FLAVOR:-}"
VERSION="${VERSION:-}"
GIT_SHA="${GIT_SHA:-}"
IMAGE_VENDOR="${IMAGE_VENDOR:-svkoulu}"
REPO_URL="https://github.com/svkoulu/svk-os"

PAREN=""
if [ -n "${IMAGE_FLAVOR}" ] && [ -n "${VERSION}" ]; then
	PAREN=" (${IMAGE_FLAVOR}-${VERSION})"
elif [ -n "${IMAGE_FLAVOR}" ]; then
	PAREN=" (${IMAGE_FLAVOR})"
elif [ -n "${VERSION}" ]; then
	PAREN=" (${VERSION})"
fi
DISPLAY_NAME="SVK OS${PAREN}"

OS_RELEASE="/usr/lib/os-release"

# --- os-release: upsert (replace the key if the base set it, append otherwise) ----
set_kv() {
	local key="$1" val="$2"
	if grep -q "^${key}=" "${OS_RELEASE}"; then
		sed -i "s|^${key}=.*|${key}=\"${val}\"|" "${OS_RELEASE}"
	else
		printf '%s="%s"\n' "${key}" "${val}" >>"${OS_RELEASE}"
	fi
}

set_kv PRETTY_NAME       "${DISPLAY_NAME}"
set_kv NAME              "svk-os"
set_kv IMAGE_ID          "${IMAGE_NAME}"
set_kv IMAGE_VENDOR      "${IMAGE_VENDOR}"
[ -n "${VERSION}" ] && set_kv IMAGE_VERSION "${VERSION}"
# BUILD_ID is systemd's own os-release(5) field for "a string that uniquely
# identifies a particular build" — the standard slot for a commit SHA, not a
# svk-invented one.
[ -n "${GIT_SHA}" ] && set_kv BUILD_ID "${GIT_SHA}"
set_kv HOME_URL          "${REPO_URL}"
set_kv DOCUMENTATION_URL "${REPO_URL}/blob/main/README.md"
set_kv SUPPORT_URL       "${REPO_URL}/issues"
set_kv BUG_REPORT_URL    "${REPO_URL}/issues/new"

# --- svk-os/image-info.json: derive channel + release line from VERSION -----------
# stable-<N>-<date> -> channel=stable, release-tag=<N>;  testing-<date> -> testing.
channel=""; release_tag=""
case "${VERSION}" in
	stable-*)  channel="stable"; rest="${VERSION#stable-}"; release_tag="${rest%-*}" ;;
	testing-*) channel="testing" ;;
	local-*)   channel="local" ;;
esac

# Fedora version + base variant come from Silverblue's own os-release (untouched).
fedora_version="$(. "${OS_RELEASE}" 2>/dev/null; echo "${VERSION_ID:-}")"
base_image="$(. "${OS_RELEASE}" 2>/dev/null; echo "${VARIANT_ID:-silverblue}")"

mkdir -p /usr/share/svk-os
cat >/usr/share/svk-os/image-info.json <<EOF
{
  "image-name": "${IMAGE_NAME}",
  "image-vendor": "${IMAGE_VENDOR}",
  "image-ref": "ostree-image-signed:docker://ghcr.io/${IMAGE_VENDOR}/${IMAGE_NAME}",
  "channel": "${channel}",
  "version": "${VERSION}",
  "git-commit": "${GIT_SHA}",
  "release-tag": "${release_tag}",
  "base-image": "${base_image}",
  "fedora-version": "${fedora_version}"
}
EOF

echo "stamped ${OS_RELEASE} + svk-os/image-info.json: IMAGE_ID=${IMAGE_NAME} VERSION=${VERSION:-<none>} channel=${channel:-<none>} GIT_SHA=${GIT_SHA:-<none>}"
