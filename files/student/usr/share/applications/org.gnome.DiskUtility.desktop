# Masks the org.gnome.DiskUtility FLATPAK (baked via flatpaks/common.list for
# both ISOs) so it never shows in opilas's app grid/search. This is NOT the
# same lockdown as build/40-desktop.sh's removal of the RPM gnome-disks
# .desktop — that one doesn't exist on this raw-Silverblue base to begin with,
# and even if it did, it wouldn't touch a flatpak's exported entry (that lives
# under /var/lib/flatpak/exports/share, populated by Titanoboa at ISO-install
# time, not at container build time). Flatpak appends its exports dir to
# XDG_DATA_DIRS, so this baked-in /usr/share/applications entry — same
# desktop-file ID — is found first and wins; the flatpak stays installed and
# fully usable by admin (sudo) or staff (svk-staff doesn't ship this file),
# it just never renders as a launchable icon for opilas. Students couldn't
# use udisks2 even if they saw the icon (49-school-lockdown.rules denies it),
# but a dead icon that errors on click is worse UX than no icon.
[Desktop Entry]
Type=Application
Name=Disks
NoDisplay=true
